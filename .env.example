# -------------------------------------------------------------
# ARQUIVO DE VARIÁVEIS DE AMBIENTE (.env)
# IMPORTANTE: Nunca envie o arquivo ".env" real para o GitHub.
# Este arquivo ".env.example" serve apenas como modelo.
# -------------------------------------------------------------

# Microsoft Clarity (Auditoria Silenciosa e Mapas de Calor)
VITE_CLARITY_ID=coloque_seu_id_aqui

# Hotjar (Alternativa de Mapa de Calor / Feedback)
VITE_HOTJAR_ID=coloque_o_id_aqui
VITE_HOTJAR_VERSION=6

# Google Analytics (Monitoramento de Tráfego)
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXX

# -------------------------------------------------------------
# Como usar:
# 1. Crie um arquivo chamado ".env" (sem o .example)
# 2. Copie este conteúdo para ele
# 3. Substitua os valores "coloque_seu_id_aqui" pelos IDs reais.
